# Supabase (optional in dev — falls back to in-memory mock store)
# Project URL from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (client-safe, sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (server-only, sb_secret_...). Never expose to the client.
SUPABASE_SECRET_KEY=

# Groq — free tier, no card required. Used for crisis-aware moderation
# (Llama 3.3 70B with a custom prompt that allows pain, blocks attacks/spam).
# https://console.groq.com/keys
GROQ_API_KEY=

# Salt for SHA-256 IP hashing (rate limiting). Pick any random string.
IP_SALT=

# Upstash Redis for rate limiting (3 submissions/hour per IP hash).
# Prod: Vercel → Storage → Upstash Redis (no Custom Prefix) injects these
# as KV_REST_API_URL / KV_REST_API_TOKEN — Redis.fromEnv() reads them.
# Local: copy the same two values from Vercel project env vars.
# Missing in dev → fallback to in-memory. Missing in prod → fail closed (429).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Public site URL — used for canonical URLs, OG/Twitter image absolute paths.
NEXT_PUBLIC_SITE_URL=https://sytt.example
